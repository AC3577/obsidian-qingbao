.png","styleMode":"deep-analysis","sourceType":"research-notes","structureFrame":"deep-analysis","disclosure":"本文基于2026年3–4月多平台公开数据（知乎/小红书/B站/Reddit）整理，由AI辅助写作，人工审核。所有案例数据均来自可追溯来源，收入数据反映样本范围，不代表普遍规律。"},"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:📤 产出/公众号/2026-04/20260414-ai-fuye-bianxian/article.md#---frontmatter---": {"path":null,"last_embed":{"hash":"mrv90t","at":1776485852267},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.06643447,-0.01965907,0.01767706,-0.03372651,0.03856901,-0.00225887,-0.01892184,0.03079417,0.05373606,-0.03013442,0.0121708,-0.04725166,0.022201,0.0204845,0.02279084,0.05387531,0.04589836,-0.07753517,-0.03969432,-0.0009699,0.14789765,-0.04829804,0.06297163,-0.1190885,-0.01514802,0.00522835,-0.01216938,-0.03383866,0.01377441,-0.14783208,-0.0076388,-0.01137442,0.10111156,0.00380064,0.04783818,-0.02444187,-0.03285537,0.05555428,-0.03684318,0.01481452,-0.00096838,0.04758396,0.06258052,-0.00383934,0.05513106,0.00998353,0.00645822,-0.06630729,-0.01291109,0.0035864,-0.01427525,-0.03590854,0.00182416,0.0396959,0.03295423,-0.0077878,0.03236477,0.00753581,0.00976209,0.02496649,0.09332893,0.02836689,-0.19622293,0.0497027,0.01774156,0.00248169,-0.01464281,-0.04160561,0.04317519,0.05075621,-0.04727463,0.00256658,0.00856179,-0.00443843,0.02316129,-0.0056372,-0.00172413,-0.03446621,-0.05288242,-0.07322182,-0.01733794,0.07330453,-0.00348013,-0.00978687,-0.02657297,0.03874613,0.01428954,-0.07848601,-0.01842907,-0.04862369,0.00360499,-0.01307418,0.00109791,0.04213402,-0.00242283,0.01205212,-0.01149165,0.03266666,-0.06570684,0.0868971,-0.07742397,-0.01977551,0.03373014,-0.03296635,0.03090799,0.02889092,-0.03617433,-0.01729365,-0.04872344,-0.01162338,-0.07378808,-0.01083417,0.08368263,-0.04618311,0.02110125,0.03185691,0.05620325,0.04149758,-0.01280957,-0.01035775,-0.00432434,0.01178515,0.01763075,0.0414515,-0.0252234,-0.0138188,0.02744466,0.06144369,0.0128352,0.00730904,0.05599044,0.0436065,-0.07294428,0.00626416,0.01957529,0.03061386,-0.03464