何具体平台或个人的评价。"},"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:📤 产出/公众号/2026-04/20260412-自我提升内容产业的心理陷阱/article.md#---frontmatter---": {"path":null,"last_embed":{"hash":"lanvfw","at":1776485850709},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05923678,0.02475966,0.00944405,-0.04761931,0.0344587,0.02856528,-0.04119847,0.00040102,0.05534272,-0.01704772,0.02283719,-0.05142305,0.03556312,0.02164604,0.03877368,0.03743736,0.02663776,-0.11372539,-0.04160874,-0.03151819,0.12417875,-0.06936964,0.02496526,-0.09235576,0.01975201,0.0031427,-0.02472155,-0.01419197,0.00340217,-0.16400228,-0.03907132,-0.01027437,0.04407545,0.00305879,0.03745207,-0.0354376,-0.0404556,0.03196819,-0.02720501,0.01715024,-0.01048057,0.02397931,0.02210336,0.04818184,0.06494629,-0.04090704,-0.0244624,-0.09216334,-0.01591817,-0.0207226,-0.02316539,-0.03866043,0.01323409,0.03643053,-0.00776007,0.01324592,0.03637381,0.00384497,0.03721391,0.04903784,0.06590234,0.01278976,-0.20627339,0.06622134,0.00570707,0.00946286,-0.04991646,-0.04067632,0.03740956,0.05736833,-0.04163521,-0.00577235,-0.01210699,0.01643087,0.06051061,-0.01817144,0.04178354,-0.0361313,-0.06335952,-0.065518,0.00649216,0.08238496,-0.00578778,0.01432839,-0.02610603,0.02880934,0.02532135,-0.05080617,-0.00509309,-0.00288939,0.0039591,-0.03819773,0.04165669,0.04451102,-0.02522731,-0.00075915,-0.01109502,0.02960445,-0.04602249,0.09577603,-0.03315152,0.01666059,0.02702942,-0.02608898,0.05947902,-0.01844938,-0.01233582,-0.01259989,-0.01277043,0.00467369,-0.04411687,0.00829248,0.05422448,-0.03265124,0.02628862,0.02952573,0.06845842,0.06978489,-0.03166754,-0.00815358,-0.00229657,-0.00071252,-0.00045412,-0.00217361,-0.02493345,-0.02315481,0.02797631,0.06594902,0.02427181,0.01316891,0.07602967,0.06044472,-0.04745568,-0.0301785,0.0071151,-0.02450087,-0.0500285,0.00770556,0.00726088,-0.02899028,-0.06453886,-0.03631474,-0.03598685,-0.07243138,-0.0635638,0.12528197,-0.04455477,-0.01056878,-0.04518063,-0.07332703,0.00852067,0.04242841,0.0218